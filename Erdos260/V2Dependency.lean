/-- Items in the gap ledger with a given alignment status. -/
def alignmentItemsWithStatus (s : AlignmentStatus) : List AlignmentItem :=
  alignmentTracker.filter (fun it => it.status = s)

/-- Count of tracked items with a given alignment status. -/
def alignmentStatusCount (s : AlignmentStatus) : Nat :=
  (alignmentItemsWithStatus s).length

/-- The active tracker condition count matches the current strongest endpoint's
open provider-field count. -/
theorem alignmentStatusCount_conditional_eq_openTheoremNames_length :
    alignmentStatusCount AlignmentStatus.conditional =
      proofV2OpenTheoremNames.length := by
  native_decide

/-- Items whose closure is scheduled in a given roadmap phase. -/
def alignmentItemsInPhase (p : String) : List AlignmentItem :=
  alignmentTracker.filter (fun it => it.phase = p)

/-- The whole proof is aligned iff no tracked item is left
`conditional`, `simplified`, or `absent`. -/
def fullyAligned : Prop :=
  ∀ it ∈ alignmentTracker, it.status = AlignmentStatus.faithful

/-- The gap ledger is non-empty (it tracks the audited dependencies). -/
theorem alignmentTracker_nonempty : alignmentTracker ≠ [] := by
  decide

/-- The whole proof is aligned: every tracked item is `faithful`. -/
theorem fullyAligned_holds : fullyAligned := by
  intro it hit
  fin_cases hit <;> decide

end Erdos260
