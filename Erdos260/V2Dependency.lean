theorem proofV2OpenTheoremNames_empty :
    proofV2OpenTheoremNames = [] := by
  rfl

theorem proofV2ClosedTheoremNames_nonempty :
    proofV2ClosedTheoremNames ≠ [] := by
  decide

theorem proofV2CurrentResidualProviderNames_nonempty :
    proofV2CurrentResidualProviderNames ≠ [] := by
  decide

theorem proofV2FinalTheoremNames_nonempty :
    proofV2FinalTheoremNames ≠ [] := by
  decide

/-- **P0 semantics.** The open residual is the remaining provider fields of the
current Appendix N chain-compression global input; the final theorem is
unconditional exactly when this list is empty. -/
theorem proofV2OpenTheoremNames_length :
    proofV2OpenTheoremNames.length = 0 := by
  simp [proofV2OpenTheoremNames]

theorem proofV2OpenPcoreLeafNames_length :
    proofV2OpenPcoreLeafNames.length = 3 := by
  simp [proofV2OpenPcoreLeafNames]

theorem proofV2OpenPcoreDirectBlockers_length :
    proofV2OpenPcoreDirectBlockers.length = 3 := by
  simp [proofV2OpenPcoreDirectBlockers]

