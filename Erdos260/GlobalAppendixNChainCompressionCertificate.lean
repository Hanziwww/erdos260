namespace CarryChernoffCanonicalYFixedZTailSmallInputData

/--
Project the proof-v4 fixed-tilt/canonical-Y carry Chernoff tail-smallness leaf
to the actual shell-paid finite-sum Chernoff surface.

The shell-paid multiplier is chosen canonically from the same finite tilted
root, so the `area_small` field is exactly the tail-smallness inequality after
unfolding the finite root.  This avoids introducing an additional arbitrary
layer-cake weight at the final actual boundary.
-/
def toActualShellPaidChernoffFiniteSumFixedTiltCanonicalYRootSmallData
    {ctx : ActualFailureContext}
    (data :
      @CarryChernoffCanonicalYFixedZTailSmallInputData ctx.shell
        erdos260Constants.cPr erdos260Constants.cStar erdos260Constants.ξ
        ctx.n24CarryData) :
    ActualShellPaidChernoffFiniteSumFixedTiltCanonicalYRootSmallData ctx where
  Path := StoppedBranch
  paths := ctx.n24CarryData.stoppedBranches
  weight := ctx.n24CarryData.stoppedBranchWeight
  cost := ctx.n24CarryData.stoppedBranchCost
  root_small := by
    simpa [carryChernoffFiniteRoot, carryChernoffFiniteTiltMass,
      ActualFailureContext.n24CarryData] using
      data.toCarryChernoffCanonicalYFixedZRootSmallInputData.root_small
  Ysh := fun b =>
    ((ctx.n24CarryData.stoppedBranches.card : Real) *
        (proofV4ChernoffTilt : Real) ^ ctx.n24CarryData.stoppedBranchCost b) /
      (proofV4ChernoffTilt : Real) ^ Nat.floor ctx.n24CarryData.Y
  hYsh := by
    intro b hb
    have hz_nonneg : 0 <= (proofV4ChernoffTilt : Real) :=
      le_of_lt (lt_trans zero_lt_one proofV4ChernoffTilt.property.1)
    exact div_nonneg
      (mul_nonneg (Nat.cast_nonneg _) (pow_nonneg hz_nonneg _))
      (pow_nonneg hz_nonneg _)
  area_small := by
    have hsum :
        (∑ b ∈ ctx.n24CarryData.stoppedBranches,
            (ctx.n24CarryData.stoppedBranchWeight b : Real) *
              (((ctx.n24CarryData.stoppedBranches.card : Real) *
                  (proofV4ChernoffTilt : Real) ^
                    ctx.n24CarryData.stoppedBranchCost b) /
                (proofV4ChernoffTilt : Real) ^ Nat.floor ctx.n24CarryData.Y)) =
          carryChernoffFiniteRoot ctx.n24CarryData (proofV4ChernoffTilt : Real) /
            (proofV4ChernoffTilt : Real) ^ Nat.floor ctx.n24CarryData.Y := by
      simp [carryChernoffFiniteRoot, carryChernoffFiniteTiltMass,
        Finset.mul_sum, div_eq_mul_inv, mul_assoc, mul_comm, mul_left_comm]
    calc
      (∑ b ∈ ctx.n24CarryData.stoppedBranches,
          (ctx.n24CarryData.stoppedBranchWeight b : Real) *
            (((ctx.n24CarryData.stoppedBranches.card : Real) *
                (proofV4ChernoffTilt : Real) ^
                  ctx.n24CarryData.stoppedBranchCost b) /
              (proofV4ChernoffTilt : Real) ^ Nat.floor ctx.n24CarryData.Y))
          = carryChernoffFiniteRoot ctx.n24CarryData (proofV4ChernoffTilt : Real) /
              (proofV4ChernoffTilt : Real) ^ Nat.floor ctx.n24CarryData.Y := hsum
      _ <= (erdos260Constants.cStar * erdos260Constants.ξ / 6) *
              (ctx.shell.X : Real) := data.tail_small
      _ = erdos260Constants.cStar * erdos260Constants.ξ *
              (ctx.shell.X : Real) / 6 := by ring

end CarryChernoffCanonicalYFixedZTailSmallInputData

