/-- Full-carry stopped-tree 22.1A data in the manuscript's layer-cake majorant
form for one Appendix N shell.

Compared with `GlobalAppendixNProofV4CarryStoppedTreeAreaLayerChernoffInputData`,
this keeps the per-level majorant `chernoff`, its integrability, the level-set
domination, and the integrated bound explicit until the projection below
derives the final finite shell-paid area smallness. -/
structure GlobalAppendixNProofV4CarryStoppedTreeLayerCakeChernoffInputData
    (shell : FailingDyadicShell)
    (carryData : CarryDataFromFailure shell erdos260Constants.cPr) where
  budget :
    @CarryChernoffStoppedTreeBudgetData shell erdos260Constants.cPr
      erdos260Constants.cStar erdos260Constants.ξ carryData
  Ysh : StoppedBranch -> Real
  hYsh :
    forall b, b ∈ carryData.stoppedBranches -> 0 <= Ysh b
  chernoff : Real -> Real
  bound : Real
  hchernoff_int : Integrable chernoff volume
  hlevel :
    forall u,
      areaLayerSum carryData.stoppedBranches
        (fun b => (carryData.stoppedBranchWeight b : Real)) Ysh u <=
          chernoff u
  hbound : ∫ u, chernoff u <= bound
  bound_small :
    bound <= erdos260Constants.cStar * erdos260Constants.ξ *
      (shell.X : Real) / 6

