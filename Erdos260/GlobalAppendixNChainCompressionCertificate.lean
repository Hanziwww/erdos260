/-- Project one raw proof-v4 code/fibre CNL field package to the actual
classical code/fibre CNL column consumed by the preferred final target. -/
def GlobalAppendixNProofV4RawCodeFibreCNLFields.toActualClassicalCodeFibreNatBudgetData
    {ctx : ActualFailureContext}
    (data : GlobalAppendixNProofV4RawCodeFibreCNLFields ctx.shell) :
    ActualCNLClassicalCodeFibreNatBudgetData ctx where
  Code := data.Code
  transitions := data.transitions
  BNDHeightNat := data.BNDHeightNat
  M := data.M
  shellFactor := data.shellFactor
  Ij := data.Ij
  code := data.code
  codeBound := data.codeBound
  fiberBound := data.fiberBound
  hcodes := by
    classical
    intro cls
    have himage :
        @Finset.image CNLTransition data.Code (Classical.decEq data.Code)
            (data.code cls) (transitionsSelectedAs data.transitions cls) =
          @Finset.image CNLTransition data.Code data.decCode
            (data.code cls) (transitionsSelectedAs data.transitions cls) := by
      apply Finset.ext
      intro y
      simp
    rw [himage]
    exact data.hcodes cls
  hfiber := by
    classical
    intro cls y hy
    have himage :
        @Finset.image CNLTransition data.Code (Classical.decEq data.Code)
            (data.code cls) (transitionsSelectedAs data.transitions cls) =
          @Finset.image CNLTransition data.Code data.decCode
            (data.code cls) (transitionsSelectedAs data.transitions cls) := by
      apply Finset.ext
      intro z
      simp
    have hfilter :
        @Finset.filter CNLTransition
            (fun t => data.code cls t = y)
            (fun t => Classical.decEq data.Code (data.code cls t) y)
            (transitionsSelectedAs data.transitions cls) =
          @Finset.filter CNLTransition
            (fun t => data.code cls t = y)
            (fun t => data.decCode (data.code cls t) y)
            (transitionsSelectedAs data.transitions cls) := by
      apply Finset.ext
      intro t
      simp
    rw [himage] at hy
    rw [hfilter]
    exact data.hfiber cls y hy
  hcodeSumNat := data.hcodeSumNat
  scalar_budget := by
    simpa [erdos260Constants] using data.scalar_budget

