/-- Raw I.5.1/M.2/J.4/L.6 return field package before the closed return record
is formed. -/
structure GlobalAppendixNProofV4RawReturnOLCMultiplicityFields
    (cStar xi X : Real) where
  ordinaryShort : Real
  semiperiodic : Real
  olc : Real
  nonlocalLong : Real
  c1 : Real
  c2 : Real
  c3 : Real
  c4 : Real
  s : Real
  ij : Real
  smallError : Real
  ML : Real
  epsilonTerm : Real
  ordinaryShort_bound :
    ordinaryShort <= c1 * xi * s * X * ij + smallError / 4
  semiperiodic_bound :
    semiperiodic <= c2 * xi * s * X * ij + smallError / 4
  olc_multiplicity :
    olc <= ML * X * ij + epsilonTerm
  olc_epsilon :
    epsilonTerm <= s * X * ij / 2
  olc_ML_budget :
    ML * X * ij <= s * X * ij / 2
  olc_return_budget :
    s * X * ij <= c3 * xi * s * X * ij + smallError / 4
  nonlocalLong_bound :
    nonlocalLong <= c4 * xi * s * X * ij + smallError / 4
  smallness :
    ReturnSmallnessInputData cStar xi X c1 c2 c3 c4 s ij smallError

