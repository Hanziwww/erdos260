/-- Structured proof-v4 N.3.3 terminal package whose bounded-class paid part
is still exposed in the finite-overlap L.6.2 form.

This is the manuscript-facing strengthening of
`AppendixNStructuredTerminalLowPaidInputData`: the only extra requirement is
that the L.6 low/paid split is supplied by the finite-overlap embedding
certificate, rather than only by its collapsed low-paid consequence. -/
structure AppendixNStructuredTerminalFiniteOverlapLowPaidInputData
    {shell : FailingDyadicShell}
    (chernoffLeaf :
      RegularShellPaidChernoff22_1AInputData erdos260Constants.cStar
        erdos260Constants.ξ (shell.X : Real))
    {carryLocal :
      ThresholdControlledStrictFailureBoundedThresholdShellGroundedCarryLocalData
        shell erdos260Constants.cPr}
    {hc0Small : shell.c0 <= manuscriptKappa / 16}
    {h_supportCount_pos : 1 <= supportCount shell.d shell.X}
    {O_V : Real}
    (variation :
      AppendixNVariationClosedN21N22InputData carryLocal hc0Small
        h_supportCount_pos O_V)
    (O_D O_P O_E O_CNL O_bdd : Real) where
  sigma : Type
  iota : Type
  linIota : LinearOrder iota
  E : @AppendixN.EventFibre sigma iota (Classical.decEq sigma) linIota
  row : iota -> AppendixN.TerminalRow
  supp : iota -> Nat
  thr : iota -> Nat
  terminalWeight : OutputObjectV4 -> Real
  terminalMass :
    @TableRoutedTerminalMassCompressionInputData sigma iota
      (Classical.decEq sigma) linIota E row supp thr terminalWeight
      (GroundedC1VDSplitData.ofVariation
        variation.toVariationClassData.toVariationClassData).termMass
  densePack :
    @TableRoutedDensePackClassSupportInputData sigma iota
      (Classical.decEq sigma) linIota E row supp thr terminalWeight
      erdos260Constants.cStar erdos260Constants.ξ (shell.X : Real) O_D
  progress :
    @TableRoutedProgressClassChernoffInputData sigma iota
      (Classical.decEq sigma) linIota E row supp thr terminalWeight
      erdos260Constants.cStar erdos260Constants.ξ (shell.X : Real) O_P
  endpoint :
    @TableRoutedEndpointClassReturnInputData sigma iota
      (Classical.decEq sigma) linIota E row supp thr terminalWeight
      erdos260Constants.cStar erdos260Constants.ξ (shell.X : Real) O_E
  cnl :
    @TableRoutedCNLClassKraftInputData sigma iota (Classical.decEq sigma)
      linIota E row supp thr terminalWeight shell erdos260Constants.cStar
      erdos260Constants.ξ O_CNL
  bddFiniteOverlap :
    ShellPaidBddClassBoundData.FiniteOverlapLowPaidSplitData chernoffLeaf
      ((@AppendixN.EventFibre.atoms sigma iota
          (Classical.decEq sigma) linIota E).image
        (fun omega =>
          { cls := (row omega).outputClass
            supportId := supp omega
            thresholdLayer := thr omega }))
      terminalWeight O_bdd

