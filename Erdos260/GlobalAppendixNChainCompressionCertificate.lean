def ofProofInputData
    {shell : FailingDyadicShell}
    (data :
      CNLStandardWeightedKraftShellProofInputData shell
        erdos260Constants.cStar erdos260Constants.ξ) :
    GlobalAppendixNProofV4RawClusterCNLFields shell :=
