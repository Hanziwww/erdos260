/-- Package the standard grounded L.1.2/G.35 cluster encoding directly at the
raw strict CNL boundary.

The selected transition family and Nat BND heights stay visible, while the
grounded cluster input supplies the ladder Kraft domination and manuscript
G.35 shell budget with the standard constants `c = 1`, `C_Q = 2`. -/
def ofGroundedClusterEncoding
    {shell : FailingDyadicShell}
    (transitions : Finset CNLTransition)
    (BNDHeightNat : CNLTransition -> Nat)
    (M : Nat)
    (shellFactor : {x : Real // 0 <= x})
    (Ij : {x : Real // 0 <= x})
    (input :
      GroundedCNLClusterEncodingInput
        (selectedTransitions transitions) (fun t => (BNDHeightNat t : Real))
        (1 : Real) (2 : Real) (shellFactor : Real) (shell.X : Real) (Ij : Real)
        erdos260Constants.cStar erdos260Constants.ξ M) :
    GlobalAppendixNProofV4RawClusterCNLFields shell where
  transitions := transitions
  BNDHeightNat := BNDHeightNat
  M := M
  shellFactor := shellFactor
  Ij := Ij
  ladderChildren := input.ladderChildren
  ladderHeight := input.ladderHeight
  ladderRoot := input.ladderRoot
  ladderHeight_dom := input.ladderHeight_dom
  cluster_le_pathKraft := by
    simpa using input.cluster_le_pathKraft
  manuscript_budget := by
    simpa using input.manuscript_bound

/-- Bundle unbundled L.1.2/G.35 cluster fields into the strict CNL cluster
provider consumed by the preferred final endpoint. -/
def toClusterInputData
    {shell : FailingDyadicShell}
    (data : GlobalAppendixNProofV4RawClusterCNLFields shell) :
    CNLStandardWeightedKraftShellClusterInputData shell
      erdos260Constants.cStar erdos260Constants.ξ :=
  CNLStandardWeightedKraftShellClusterInputData.ofLadderKraftBudget
    data.transitions data.BNDHeightNat data.M data.shellFactor data.Ij
    data.ladderChildren data.ladderHeight data.ladderRoot
    data.ladderHeight_dom data.cluster_le_pathKraft data.manuscript_budget

end GlobalAppendixNProofV4RawClusterCNLFields

